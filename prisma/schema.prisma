generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  VENDOR
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum CertificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

model User {
  id             String          @id @default(uuid())
  name           String
  email          String          @unique
  password       String
  role           Role
  status         UserStatus      @default(ACTIVE)
  vendorProfile  VendorProfile?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  orders         Order[]
  bookings       Booking[]
  communityPosts CommunityPost[]
  plants         Plant[]

  @@index([role])
  @@index([status])
}

model VendorProfile {
  id                  String               @id @default(ulid())
  farmName            String
  farmLocation        String
  latitude            Float
  longitude           Float
  certificationStatus CertificationStatus  @default(PENDING)
  userId              String               @unique
  user                User                 @relation(fields: [userId], references: [id])
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  produces            Produce[]
  rentalSpaces        RentalSpace[]
  sustainabilityCerts SustainabilityCert[]

  @@index([latitude, longitude])
}

model Produce {
  id                  String              @id @default(uuid())
  vendorId            String
  name                String
  description         String
  price               Float
  category            String
  certificationStatus CertificationStatus @default(PENDING)
  availableQuantity   Int

  vendor    VendorProfile @relation(fields: [vendorId], references: [id])
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  orders    Order[]

  @@index([vendorId])
  @@index([category])
  @@index([certificationStatus])
}

model RentalSpace {
  id          String        @id @default(uuid())
  vendorId    String
  vendor      VendorProfile @relation(fields: [vendorId], references: [id])
  location    String
  latitude    Float
  longitude   Float
  size        String
  price       Float
  isAvailable Boolean       @default(true)
  createdAt   DateTime      @default(now())
  bookings    Booking[]

  @@index([vendorId])
  @@index([latitude, longitude])
}

model Order {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  produceId String
  produce   Produce  @relation(fields: [produceId], references: [id])
  vendorId  String
  status    String   @default("PENDING")
  orderDate DateTime @default(now())

  @@index([userId])
  @@index([vendorId])
  @@index([produceId])
  @@index([status])
}

model Booking {
  id            String   @id @default(uuid())
  userId        String
  rentalSpaceId String
  startDate     DateTime
  endDate       DateTime

  user        User        @relation(fields: [userId], references: [id])
  rentalSpace RentalSpace @relation(fields: [rentalSpaceId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([rentalSpaceId])
}

model CommunityPost {
  id          String   @id @default(uuid())
  userId      String
  postContent String
  postDate    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model SustainabilityCert {
  id                String   @id @default(uuid())
  vendorId          String
  certifyingAgency  String
  certificationDate DateTime

  vendor VendorProfile @relation(fields: [vendorId], references: [id])

  createdAt DateTime @default(now())

  @@index([vendorId])
}

model Plant {
  id           String    @id @default(uuid())
  userId       String
  name         String
  growthStage  String
  healthStatus String
  plantedAt    DateTime
  harvestAt    DateTime?

  user User @relation(fields: [userId], references: [id])

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  plantUpdates PlantUpdate[]

  @@index([userId])
}

model PlantUpdate {
  id        String   @id @default(uuid())
  plantId   String
  updateMsg String
  health    String
  createdAt DateTime @default(now())

  plant Plant @relation(fields: [plantId], references: [id])
}
